rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // FIX: call getUserData() once — avoids double get() in isActiveStudent
    function isAdmin() {
      let role = getUserData().role;
      return isAuth() && (role == 'admin' || role == 'owner' || role == 'assistant');
    }

    function isOwnerRole() {
      return isAuth() && getUserData().role == 'owner';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // FIX: single get() call — previous version called get() twice which could
    // cause rule evaluation failures when isActive was missing or null.
    function isActiveStudent() {
      let data = getUserData();
      return isAuth() && data.role == 'student' && data.isActive == true;
    }

    // ═══════════════════════════════════════════
    //  USERS COLLECTION
    // ═══════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);

      allow create: if isAdmin();

      // FIX: added 'devices' to the allowed fields so DeviceService.checkAndRegister()
      // can write fingerprints without a permission error crashing the auth flow.
      allow update: if isAdmin() || (
        isOwner(userId) && onlyUpdatingFields(['name', 'updatedAt', 'devices'])
      );

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    //  GROUPS COLLECTION
    // ═══════════════════════════════════════════
    match /groups/{groupId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  ATTENDANCE COLLECTION
    // ═══════════════════════════════════════════
    match /attendance/{recordId} {
      allow read: if isAdmin() ||
        (isActiveStudent() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  GRADES COLLECTION
    // ═══════════════════════════════════════════
    match /grades/{gradeId} {
      allow read: if isAdmin() ||
        (isActiveStudent() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  EXAMS COLLECTION
    // ═══════════════════════════════════════════
    match /exams/{examId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  ASSIGNMENTS COLLECTION
    // ═══════════════════════════════════════════
    match /assignments/{assignId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isActiveStudent() && onlyUpdatingSubmissions());
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  NOTIFICATIONS COLLECTION
    // ═══════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.toUid == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isAuth() && resource.data.toUid == request.auth.uid && onlyUpdatingFields(['isRead']));
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  LESSONS COLLECTION
    // ═══════════════════════════════════════════
    match /lessons/{lessonId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() ||
        (isActiveStudent() && onlyUpdatingLessonAccess());
    }

    // ═══════════════════════════════════════════
    //  ANALYTICS COLLECTION
    // ═══════════════════════════════════════════
    match /analytics/{groupId} {
      allow read: if isAdmin() ||
        (isActiveStudent() &&
          getUserData().groupId == groupId);
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  PERMISSION REQUESTS COLLECTION
    // ═══════════════════════════════════════════
    match /permission_requests/{reqId} {
      allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid;
      allow read:   if isAdmin() ||
        (isAuth() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  CODES COLLECTION (global stage-based codes)
    // ═══════════════════════════════════════════
    match /codes/{codeId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() ||
        (isActiveStudent() && onlyUpdatingFields(['isUsed','usedBy','usedAt','lessonId']));
    }

    // ═══════════════════════════════════════════
    //  LESSON CODES COLLECTION
    // ═══════════════════════════════════════════
    match /lesson_codes/{codeId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isActiveStudent() && onlyUpdatingFields(['isUsed','usedBy','usedAt','lessonId']));
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  HELPER RULE FUNCTIONS
    // ═══════════════════════════════════════════

    function onlyUpdatingFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function onlyUpdatingSubmissions() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.size() == 1 && changedKeys.hasAll(['submissions']);
    }

    function onlyUpdatingLessonAccess() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(['accessList', 'codeUsed']);
    }
  }
}
